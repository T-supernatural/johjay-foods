# Django environment settings
SECRET_KEY=your-generated-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres settings (optional)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration
# Set EMAIL_BACKEND_MODE to 'console' for development (emails print to terminal)
# Set EMAIL_BACKEND_MODE to 'smtp' to send real emails via Gmail
EMAIL_BACKEND_MODE=console
FRONTEND_URL=http://localhost:5173

# Gmail SMTP Configuration (only needed when EMAIL_BACKEND_MODE=smtp)
# To set up Gmail for email sending:
#
# 1. Use a Gmail account (preferably a business Gmail if available)
# 2. Enable 2-Step Verification:
#    - Go to myaccount.google.com/security
#    - Enable 2-Step Verification on your account
# 3. Generate an App Password:
#    - Go to myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device type)
#    - Google will generate a 16-character app password
# 4. Use that App Password below, NOT your regular Gmail password
#
# Email sending examples:
# EMAIL_HOST_USER=business@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=Johjay Foods <business@gmail.com>
# BUSINESS_OWNER_EMAIL=owner@gmail.com
